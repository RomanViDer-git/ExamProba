<Window x:Class="Obuv_Prob.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuv_Prob"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Обувной магазин" FontSize="32" Grid.Column="1"/>
        <TextBlock Text="{Binding Users.Name}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin=" 0 0 10 0" FontSize="12" Grid.Column="1"/>
        <Image Grid.Column="0" Source="/pictures/Icon.png"/>
        <TabControl Grid.Column="1" Grid.Row="1" HorizontalAlignment="Stretch">
            <TabItem Header="Главная">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ListBox Name="ProductLB" Grid.Row="1" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="LightGreen" Padding="5" Margin="5" BorderThickness="1" >
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" >
                                            <Image Source="{Binding Photo}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel/>
                                        <StackPanel Grid.Column="1" Orientation="Vertical">
                                            <StackPanel Orientation="Horizontal" Margin="10 5 15  0">
                                                <TextBlock Text="{Binding Category.Category_Name}" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Text="|" FontWeight="Bold" FontSize="12"/>
                                                <TextBlock Text="{Binding Product_Name}" FontWeight="Bold" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Discription, StringFormat='Описание товара: {0}'}" FontSize="10" Margin="10 1 15  0"/>
                                            <TextBlock Text="{Binding Manufactures.Manufacturer_Name, StringFormat='Производитель: {0}'}" FontSize="10" Margin="10 1 15  0"/>
                                            <TextBlock Text="{Binding Suppliers.Supplier_Name, StringFormat='Поставщик: {0}'}" FontSize="10" Margin="10 1 15  0"/>
                                            <TextBlock Text="{Binding Price, StringFormat='Цена: {0}'}" FontSize="10" Margin="10 1 15  0"/>
                                            <TextBlock Text="{Binding Unit, StringFormat='Единаца измерения: {0}'}" FontSize="10" Margin="10 1 15  0"/>
                                            <TextBlock Text="{Binding Quantity, StringFormat='Количество на складе: {0}'}" FontSize="10" Margin="10 1 15  0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
            <TabItem Header="Админ">
                
            </TabItem>
        </TabControl>
    </Grid>
</Window>
