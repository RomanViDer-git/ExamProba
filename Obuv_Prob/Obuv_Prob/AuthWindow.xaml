<Window x:Class="Obuv_Prob.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuv_Prob"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="AuthWindow" Height="350" Width="250">
    <Grid>
        <StackPanel Margin="30 20 30 20">
            <TextBlock Text="Авторизация" FontSize="24" HorizontalAlignment="Center"/>
            <StackPanel Margin="10 50 10 30" VerticalAlignment="Center">
                <TextBlock Text="Логин"/>
                <TextBox Name="LoginTB" Text="94d5ous@gmail.com"/>
                <TextBlock Text="Пароль" Margin="0 10 0 0"/>
                <PasswordBox Name="PasswordTB"/>
                <Button Name="AuthBtn" Content="Войти" Margin="0 30 0 0" Click="AuthBtn_Click"/>
                
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
